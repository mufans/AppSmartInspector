# SmartInspector LLM Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Model ──────────────────────────────────────────────────────
# Default model for all roles (orchestrator, perf analyzer, reporter, etc.)
# Supports any OpenAI-compatible model name
SI_MODEL=deepseek-chat

# ── API Endpoint ───────────────────────────────────────────────
# Base URL for OpenAI-compatible API (override for different providers)
# DeepSeek:  https://api.deepseek.com
# OpenAI:    https://api.openai.com/v1
# Local:     http://localhost:11434/v1  (Ollama)
# Other:     https://your-proxy.example.com/v1
SI_BASE_URL=https://api.deepseek.com

# ── API Key ────────────────────────────────────────────────────
# API key for the LLM provider
# Falls back to OPENAI_API_KEY if not set
SI_API_KEY=

# ── Role-specific overrides ────────────────────────────────────
# Override model for specific roles (optional)
# Attributor benefits from a stronger code-understanding model
# SI_ATTRIBUTOR_MODEL=claude-sonnet-4-20250514
